# ==============================================================================
# Project-Team-Management Root Environment Variables Reference
# Copy the variables below to their respective paths:
#   - Backend: ./backend/.env
#   - Frontend: ./frontend/.env.local
# ==============================================================================

# ------------------------------------------------------------------------------
# Backend Configuration (.env)
# ------------------------------------------------------------------------------
# Database Connection URL (e.g. MySQL, PostgreSQL, SQLite, etc.)
DATABASE_URL="mysql://root:YOUR_PASSWORD@localhost:3306/project_management"

# API Port
PORT=5000

# JSON Web Token Secret
JWT_SECRET="your_secret_key_here"

# ------------------------------------------------------------------------------
# Frontend Configuration (.env.local)
# ------------------------------------------------------------------------------
# Base API URL endpoint pointing to backend
NEXT_PUBLIC_API_URL="http://localhost:5000/api"
